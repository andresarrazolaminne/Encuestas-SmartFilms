{
  "sections": [
    {
      "id": "sec_1",
      "title": "1. Información básica",
      "order": 1,
      "fields": [
        {
          "id": "ciudad",
          "type": "text",
          "label": "¿En qué ciudad o municipio resides actualmente?",
          "required": true,
          "placeholder": "Ej: Medellín"
        },
        {
          "id": "programa",
          "type": "select",
          "label": "¿En qué programa de SMARTFILMS participaste?",
          "required": true,
          "options": [
            "Ruta Magenta",
            "SMARTFILMS Medellín",
            "SMARTFILMS Barranquilla",
            "SMARTFILMS Bogotá",
            "Otro"
          ]
        },
        {
          "id": "anio",
          "type": "number",
          "label": "¿En qué año participaste?",
          "required": true,
          "min": 2000,
          "max": 2030,
          "placeholder": "Ej: 2024"
        },
        {
          "id": "estrato",
          "type": "select",
          "label": "¿A qué estrato socioeconómico perteneces?",
          "required": true,
          "options": ["Estrato 1", "Estrato 2", "Estrato 3", "Estrato 4", "Estrato 5", "Estrato 6"]
        }
      ]
    },
    {
      "id": "sec_2",
      "title": "2. Situación antes de participar",
      "order": 2,
      "fields": [
        {
          "id": "situacion_antes",
          "type": "select",
          "label": "Antes de participar en el programa, tu situación laboral era:",
          "required": true,
          "options": [
            "Desempleado",
            "Estudiante",
            "Empleado formal",
            "Trabajador independiente",
            "Emprendedor",
            "Otro"
          ]
        },
        {
          "id": "experiencia_antes",
          "type": "select",
          "label": "Antes de participar, ¿tenías experiencia en producción audiovisual?",
          "required": true,
          "options": ["Ninguna", "Básica", "Intermedia", "Profesional"]
        },
        {
          "id": "ingreso_antes",
          "type": "select",
          "label": "Antes de participar en SMARTFILMS, ¿cuál era tu ingreso mensual aproximado?",
          "required": true,
          "options": [
            "No tenía ingresos",
            "Menos de $500.000",
            "$500.000 – $1.000.000",
            "$1.000.000 – $2.000.000",
            "Más de $2.000.000"
          ]
        }
      ]
    },
    {
      "id": "sec_3",
      "title": "3. Situación después de participar",
      "order": 3,
      "fields": [
        {
          "id": "situacion_actual",
          "type": "select",
          "label": "Actualmente tu situación laboral es:",
          "required": true,
          "options": [
            "Empleado en sector audiovisual",
            "Empleado en otro sector",
            "Freelance en producción audiovisual",
            "Emprendedor en industria creativa",
            "Estudiante",
            "Desempleado"
          ]
        },
        {
          "id": "genera_ingresos",
          "type": "select",
          "label": "¿Actualmente generas ingresos gracias a actividades relacionadas con el audiovisual o la creación de contenido?",
          "required": true,
          "options": ["Sí", "No", "Parcialmente"]
        },
        {
          "id": "ingreso_actual",
          "type": "select",
          "label": "¿Cuál es tu ingreso mensual actual aproximado?",
          "required": true,
          "options": [
            "No tengo ingresos",
            "Menos de $500.000",
            "$500.000 – $1.000.000",
            "$1.000.000 – $2.000.000",
            "$2.000.000 – $5.000.000",
            "$5.000.000 – $10.000.000",
            "Más de $10.000.000"
          ]
        }
      ]
    },
    {
      "id": "sec_4",
      "title": "4. Emprendimiento",
      "order": 4,
      "fields": [
        {
          "id": "proyecto_empresa",
          "type": "select",
          "label": "¿Has creado algún proyecto o empresa relacionada con audiovisual o contenidos digitales después de participar en SMARTFILMS?",
          "required": true,
          "options": ["Sí", "No", "Estoy en proceso"]
        },
        {
          "id": "personas_trabajan",
          "type": "select",
          "label": "Si respondiste sí, ¿cuántas personas trabajan contigo?",
          "required": false,
          "options": ["Solo yo", "2–3 personas", "4–10 personas", "Más de 10"]
        }
      ]
    },
    {
      "id": "sec_5",
      "title": "5. Impacto social",
      "order": 5,
      "fields": [
        {
          "id": "mejoro_oportunidades",
          "type": "select",
          "label": "¿Consideras que participar en SMARTFILMS mejoró tus oportunidades laborales?",
          "required": true,
          "options": ["Mucho", "Algo", "Poco", "Nada"]
        },
        {
          "id": "nuevas_oportunidades",
          "type": "select",
          "label": "¿Participar en SMARTFILMS te permitió acceder a nuevas oportunidades educativas o profesionales?",
          "required": true,
          "options": ["Sí", "No"]
        },
        {
          "id": "proyecto_vida",
          "type": "select",
          "label": "¿El programa influyó positivamente en tu proyecto de vida?",
          "required": true,
          "options": ["Mucho", "Algo", "Poco", "Nada"]
        }
      ]
    },
    {
      "id": "sec_6",
      "title": "6. Contexto de vulnerabilidad (muy importante para impacto social)",
      "order": 6,
      "fields": [
        {
          "id": "situacion_antes_vuln",
          "type": "select",
          "label": "Antes de participar en SMARTFILMS, ¿vivías en alguna de estas situaciones?",
          "required": true,
          "options": [
            "Zona con presencia de violencia o conflicto armado",
            "Barrio o comunidad con alta vulnerabilidad social",
            "Desempleo prolongado",
            "Falta de acceso a educación superior",
            "Ninguna de las anteriores"
          ]
        },
        {
          "id": "alejarse_riesgo",
          "type": "select",
          "label": "¿Participar en SMARTFILMS te ayudó a alejarte de situaciones de riesgo social?",
          "required": true,
          "options": ["Sí", "No", "Parcialmente"]
        }
      ]
    },
    {
      "id": "sec_7",
      "title": "7. Impacto cultural",
      "order": 7,
      "fields": [
        {
          "id": "producido_contenidos",
          "type": "select",
          "label": "Después de participar en SMARTFILMS, ¿has producido contenidos audiovisuales?",
          "required": true,
          "options": ["Sí", "No"]
        },
        {
          "id": "cantidad_contenidos",
          "type": "select",
          "label": "¿Cuántos contenidos has producido aproximadamente?",
          "required": false,
          "options": ["1–3", "4–10", "10–20", "Más de 20"]
        }
      ]
    },
    {
      "id": "sec_8",
      "title": "8. Testimonio (muy valioso para prensa)",
      "order": 8,
      "fields": [
        {
          "id": "testimonio",
          "type": "textarea",
          "label": "En una frase, ¿cómo cambió SMARTFILMS tu vida?",
          "required": true,
          "placeholder": "Escribe tu testimonio aquí...",
          "rows": 4
        }
      ]
    }
  ]
}
